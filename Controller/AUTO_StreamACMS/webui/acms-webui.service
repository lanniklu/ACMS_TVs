[Unit]
Description=ACMS WebUI - Interface administration
After=network.target

[Service]
User=acms_tech
WorkingDirectory=/home/acms_tech/AUTO_StreamACMS/webui
ExecStart=python3 /home/acms_tech/AUTO_StreamACMS/webui/server.py
Restart=always
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
